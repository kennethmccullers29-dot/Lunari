"use client";

import { useState } from "react";
import Link from "next/link";
import { usePathname } from "next/navigation";
import { clsx } from "clsx";
import { signOut } from "@/lib/actions/auth";
import { CreateChannelModal } from "@/components/channel/create-channel-modal";
import { StartDmModal } from "@/components/dm/start-dm-modal";
import { StatusDot } from "@/components/presence/status-dot";
import { Avatar } from "@/components/ui/avatar";
import { usePresenceStatus } from "@/lib/hooks/use-presence-status";
import type { ProfileStatus } from "@/lib/types/database";

type Member = { id: string; display_name: string; status: ProfileStatus };
type ChannelItem = { id: string; name: string; is_private: boolean };
type DmItem = { id: string; label: string };

export function WorkspaceSidebar({
  workspaceId,
  workspaceName,
  joinCode,
  channels,
  dms,
  members,
  currentUser,
}: {
  workspaceId: string;
  workspaceName: string;
  joinCode: string;
  channels: ChannelItem[];
  dms: DmItem[];
  members: Member[];
  currentUser: Member;
}) {
  const pathname = usePathname();
  const [modal, setModal] = useState<"channel" | "dm" | null>(null);
  const statuses = usePresenceStatus(currentUser.id, members);
  const otherMembers = members.filter((m) => m.id !== currentUser.id);

  return (
    <aside className="flex h-full w-64 shrink-0 flex-col bg-[#3F0E40] text-white">
      <Link
        href="/workspaces"
        className="flex items-center justify-between border-b border-white/10 px-4 py-3.5 hover:bg-white/5"
      >
        <span className="truncate text-[15px] font-bold">{workspaceName}</span>
        <span className="text-white/50">⌄</span>
      </Link>
      <p
        className="truncate px-4 py-2 text-xs text-white/40"
        title="Share this code to invite teammates"
      >
        Join code: <span className="font-mono">{joinCode}</span>
      </p>

      <nav className="flex-1 overflow-y-auto px-2 pb-3">
        <SidebarSection title="Channels" onAdd={() => setModal("channel")}>
          {channels.map((c) => {
            const href = `/w/${workspaceId}/c/${c.id}`;
            return (
              <SidebarLink key={c.id} href={href} active={pathname === href}>
                <span className="text-white/50">{c.is_private ? "🔒" : "#"}</span> {c.name}
              </SidebarLink>
            );
          })}
          {channels.length === 0 && <EmptyHint>No channels yet</EmptyHint>}
        </SidebarSection>

        <SidebarSection title="Direct messages" onAdd={() => setModal("dm")}>
          {dms.map((d) => {
            const href = `/w/${workspaceId}/dm/${d.id}`;
            return (
              <SidebarLink key={d.id} href={href} active={pathname === href}>
                {d.label}
              </SidebarLink>
            );
          })}
          {dms.length === 0 && <EmptyHint>No conversations yet</EmptyHint>}
        </SidebarSection>

        <SidebarSection title="Members">
          {members.map((m) => (
            <div
              key={m.id}
              className="flex items-center gap-2 rounded-md px-2.5 py-1.5 text-sm text-white/70"
            >
              <StatusDot status={statuses[m.id] ?? m.status} />
              <span className="truncate">{m.display_name}</span>
              {m.id === currentUser.id && <span className="text-xs text-white/30">(you)</span>}
            </div>
          ))}
        </SidebarSection>
      </nav>

      <div className="border-t border-white/10 p-3">
        <div className="mb-2 flex items-center gap-2">
          <div className="relative shrink-0">
            <Avatar name={currentUser.display_name} size={32} />
            <span className="absolute -bottom-0.5 -right-0.5 flex h-3 w-3 items-center justify-center rounded-full bg-[#3F0E40]">
              <StatusDot status={statuses[currentUser.id] ?? currentUser.status} />
            </span>
          </div>
          <span className="truncate text-sm font-medium">{currentUser.display_name}</span>
        </div>
        <form action={signOut}>
          <button type="submit" className="text-xs text-white/50 hover:text-white hover:underline">
            Log out
          </button>
        </form>
      </div>

      {modal === "channel" && (
        <CreateChannelModal
          workspaceId={workspaceId}
          members={otherMembers}
          onClose={() => setModal(null)}
        />
      )}
      {modal === "dm" && (
        <StartDmModal
          workspaceId={workspaceId}
          members={otherMembers}
          onClose={() => setModal(null)}
        />
      )}
    </aside>
  );
}

function SidebarSection({
  title,
  onAdd,
  children,
}: {
  title: string;
  onAdd?: () => void;
  children: React.ReactNode;
}) {
  return (
    <div className="mb-4">
      <div className="mb-1 flex items-center justify-between px-2.5 pt-3">
        <h3 className="text-xs font-semibold uppercase tracking-wide text-white/40">{title}</h3>
        {onAdd && (
          <button
            onClick={onAdd}
            className="text-base leading-none text-white/40 hover:text-white"
            aria-label={`Add ${title}`}
          >
            +
          </button>
        )}
      </div>
      <div className="space-y-0.5">{children}</div>
    </div>
  );
}

function SidebarLink({
  href,
  active,
  children,
}: {
  href: string;
  active: boolean;
  children: React.ReactNode;
}) {
  return (
    <Link
      href={href}
      className={clsx(
        "block truncate rounded-md px-2.5 py-1.5 text-[14px]",
        active ? "bg-white/15 font-bold text-white" : "text-white/70 hover:bg-white/10 hover:text-white"
      )}
    >
      {children}
    </Link>
  );
}

function EmptyHint({ children }: { children: React.ReactNode }) {
  return <p className="px-2.5 py-1 text-xs text-white/30">{children}</p>;
}
