import Link from "next/link";
import { clsx } from "clsx";
import { Tooltip, TooltipContent, TooltipTrigger } from "@/components/ui/tooltip";

type WorkspaceItem = { id: string; name: string };

export function WorkspaceSwitcher({
  workspaces,
  currentWorkspaceId,
}: {
  workspaces: WorkspaceItem[];
  currentWorkspaceId: string;
}) {
  return (
    <aside className="flex h-full w-16 shrink-0 flex-col items-center gap-2 bg-[#2c0a2e] py-3">
      {workspaces.map((w) => {
        const active = w.id === currentWorkspaceId;
        return (
          <Tooltip key={w.id}>
            <TooltipTrigger asChild>
              <Link
                href={`/w/${w.id}`}
                className={clsx(
                  "flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-sm font-bold transition-all",
                  active
                    ? "bg-white text-[#3F0E40]"
                    : "bg-white/10 text-white hover:rounded-xl hover:bg-white/20"
                )}
              >
                {w.name.trim().charAt(0).toUpperCase() || "?"}
              </Link>
            </TooltipTrigger>
            <TooltipContent side="right">{w.name}</TooltipContent>
          </Tooltip>
        );
      })}
      <Tooltip>
        <TooltipTrigger asChild>
          <Link
            href="/workspaces"
            className="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-dashed border-white/30 text-lg leading-none text-white/60 hover:border-white hover:text-white"
          >
            +
          </Link>
        </TooltipTrigger>
        <TooltipContent side="right">Add or join a workspace</TooltipContent>
      </Tooltip>
    </aside>
  );
}
